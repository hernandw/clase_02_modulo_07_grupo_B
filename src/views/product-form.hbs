<section class="section">
  <h2>{{formTitle}}</h2>

  <form class="form" action="{{action}}" method="POST">
    <input
      type="text"
      name="name"
      placeholder="Nombre"
      value="{{product.name}}"
      required
    />

    <textarea
      name="description"
      placeholder="Descripción"
    >{{product.description}}</textarea>

    <input
      type="number"
      name="price"
      placeholder="Precio"
      value="{{product.price}}"
      required
    />

    <input
      type="text"
      name="image_url"
      placeholder="Ruta imagen"
      value="{{product.image_url}}"
      required
    />

    <button class="btn" type="submit">
      {{#if isEdit}}Actualizar producto{{else}}Crear producto{{/if}}
    </button>
  </form>
</section>