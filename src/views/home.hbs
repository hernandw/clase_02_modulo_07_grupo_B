<section class="hero">
  <img src="/images/hero.png" alt="Catálogo" class="hero-img" />
  <div class="hero-content">
    <h2>Bienvenido al catálogo de productos</h2>
    <p>Ejemplo simple para aprender MVC con Node y Handlebars.</p>
  </div>
</section>

<section class="section">
  <div class="section-head">
    <h2>Productos destacados</h2>
    <a class="btn" href="/productos">Ver todos</a>
  </div>

  <div class="cards">
    {{#each products}}
      <article class="card">
        <img src="{{this.image_url}}" alt="{{this.name}}" class="card-img" />
        <h3>{{this.name}}</h3>
        <p>{{this.description}}</p>
        <p><strong>Precio:</strong> ${{this.price}}</p>
      </article>
    {{/each}}
  </div>
</section>